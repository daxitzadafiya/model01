# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Website admin user (created/updated on server start when both are set)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# API KEYS OPTIMA CRM (v3 — used by properties block)
NEXT_PUBLIC_CRM_API_URL=
NEXT_PUBLIC_CRM_API_KEY=
# Contact form Yii endpoint (accounts/index). Also used for property PDF brochures (?r=pdf).
NEXT_PUBLIC_CRM_API_URL_CONTACT=
# Optima user key (property detail view + PDF brochure)
NEXT_PUBLIC_OPTIMA_USER_KEY=
NEXT_PUBLIC_OPTIMA_BROCHURE_TEMPLATE_ID=39

# OPTIMA IMAGE CONFIG (optional, falls back to defaults in code)
NEXT_PUBLIC_OPTIMA_IMAGE_URL_WITHOUT_RESIZE=https://images.optima-crm.com/cms_medias/
NEXT_PUBLIC_OPTIMA_IMAGE_URL=https://images.optima-crm.com/resize/cms_medias/
NEXT_PUBLIC_OPTIMA_COM_IMG=https://images.optima-crm.com/commercial_images
NEXT_PUBLIC_OPTIMA_AGENCY_ID=65aa5f9a641ef2183d024da8
NEXT_PUBLIC_OPTIMA_PROPERTY_RESIZE_BASE=https://images.optima-crm.com/resize/commercial_images/
NEXT_PUBLIC_OPTIMA_SITE_ID=237

# DeepL API (auto-translates missing UI strings via t())
DEEPL_API_URL=https://api.deepl.com
DEEPL_API_KEY=
# Google Maps (property search map modal)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# reCAPTCHA (server secret required for contact form verification)
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY_HERE
RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY_HERE
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY_HERE